<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Multi-participant support for event participation - individual records approach -->
    <changeSet id="multi-participant-individual-records-001" author="anabor">
        <comment>Convert multi-participant support to use individual EventParticipant records instead of count field</comment>

        <!-- Create additional records for existing multi-participant records -->
        <!-- Use a more robust approach with generate_series for proper duplication -->
        <sql>
            INSERT INTO event_participants (id, event_id, user_id, created_at, version)
            SELECT gen_random_uuid(),
                   ep.event_id,
                   ep.user_id,
                   ep.created_at,
                   0 as version
            FROM event_participants ep
            CROSS JOIN generate_series(1, (ep.participant_count - 1))
            WHERE ep.participant_count > 1;
        </sql>

        <!-- Drop the participant_count column as it's no longer needed -->
        <dropColumn tableName="event_participants" columnName="participant_count"/>
    </changeSet>

</databaseChangeLog>