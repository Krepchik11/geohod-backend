<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="2.1-add-payment-gateway-url-to-user-settings" author="naborshchikov">
        <addColumn tableName="user_settings">
            <column name="payment_gateway_url" type="VARCHAR(500)"/>
        </addColumn>

        <addColumn tableName="user_settings">
            <column name="show_become_organizer" type="BOOLEAN" defaultValue="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="2.1-add-user-settings-performance-index" author="naborshchikov">
        <createIndex indexName="idx_user_settings_user_id" tableName="user_settings" unique="false">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>