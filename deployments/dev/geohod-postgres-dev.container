[Unit]
Description=Geohod Postgres (dev)
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/library/postgres:17-alpine
ContainerName=geohod-postgres-dev
EnvironmentFile=%h/geohod-backend-dev/postgres.env
Volume=geohod-postgres-dev-data.volume:/var/lib/postgresql/data
Network=geohod-net-dev.network
HealthCmd=pg_isready
HealthInterval=10s
HealthTimeout=5s
HealthRetries=5

[Service]
Restart=always

[Install]
WantedBy=default.target
